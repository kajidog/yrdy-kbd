AWS_REGION=ap-northeast-1
BFF_ADDR=:8080
PUBLISHER_ORIGIN=http://localhost:5173
VIEWER_ORIGIN=http://localhost:5174
# Where live/recording metadata is persisted (JSON file)
BFF_DATA_FILE=data/lives.json
# KVS stream retention for recordings, in hours
KVS_RETENTION_HOURS=72

# Structured JSON logging / Datadog unified service tags
LOG_LEVEL=info
DD_SERVICE=yrdy-kbd-bff
DD_ENV=local
DD_VERSION=dev
