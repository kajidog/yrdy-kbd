VITE_BFF_BASE_URL=http://localhost:8080
# Cognito user pool used for sign-in. Leave empty to run in dev mode
# (locally minted unsigned tokens; the BFF trusts them because signature
# verification happens at CloudFront/Lambda@Edge in production).
VITE_COGNITO_REGION=ap-northeast-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
